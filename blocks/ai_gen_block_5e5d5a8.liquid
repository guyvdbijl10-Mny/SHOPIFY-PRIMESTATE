{% doc %}
  @prompt
    please insert a white backround with a text box, make sure i can adjust the font size and type 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-text-box-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding }}px;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-text-box__content-{{ ai_gen_id }} {
    font-family: {{ block.settings.font_family.family }}, {{ block.settings.font_family.fallback_families }};
    font-weight: {{ block.settings.font_family.weight }};
    font-style: {{ block.settings.font_family.style }};
    font-size: {{ block.settings.font_size }}px;
    line-height: {{ block.settings.line_height }};
    color: {{ block.settings.text_color }};
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-text-box__content-{{ ai_gen_id }} h1,
  .ai-text-box__content-{{ ai_gen_id }} h2,
  .ai-text-box__content-{{ ai_gen_id }} h3,
  .ai-text-box__content-{{ ai_gen_id }} h4,
  .ai-text-box__content-{{ ai_gen_id }} h5,
  .ai-text-box__content-{{ ai_gen_id }} h6 {
    margin-top: 0;
    margin-bottom: 0.5em;
  }

  .ai-text-box__content-{{ ai_gen_id }} p {
    margin-top: 0;
    margin-bottom: 1em;
  }

  .ai-text-box__content-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-text-box-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-text-box__content-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-text-box-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-text-box__content-{{ ai_gen_id }}">
    {% if block.settings.text != blank %}
      {{ block.settings.text }}
    {% else %}
      <p>Add your text content here. You can adjust the font size, type, and styling in the block settings.</p>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Text box",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Add your text content here</p>"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "font_family",
      "label": "Font",
      "default": "sans-serif"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 12,
      "max": 48,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "select",
      "id": "line_height",
      "label": "Line height",
      "options": [
        {
          "value": "1.2",
          "label": "Tight"
        },
        {
          "value": "1.5",
          "label": "Normal"
        },
        {
          "value": "1.8",
          "label": "Loose"
        }
      ],
      "default": "1.5"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Text box"
    }
  ]
}
{% endschema %}
