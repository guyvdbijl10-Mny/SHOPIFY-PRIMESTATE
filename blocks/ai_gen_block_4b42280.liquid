{% doc %}
  @prompt
    Put in a block with so i can put a backround image, a text box, and a learn more banner, i also want to be able to give the text box its own backround. i need top/bottom, left/right padding options, i need to be able to edit the size of the section, edit different fonts and sizes, and to add a radius 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-content-card-{{ ai_gen_id }} {
    display: block;
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    min-height: {{ block.settings.section_height }}px;
    border-radius: {{ block.settings.section_border_radius }}px;
    overflow: hidden;
  }

  .ai-content-card__background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .ai-content-card__background-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-content-card__background-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-content-card__background-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-content-card__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
    z-index: 2;
  }

  .ai-content-card__content-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    padding-left: {{ block.settings.padding_left }}px;
    padding-right: {{ block.settings.padding_right }}px;
    display: flex;
    flex-direction: column;
    align-items: {{ block.settings.content_alignment }};
    justify-content: {{ block.settings.content_vertical_alignment }};
    min-height: {{ block.settings.section_height }}px;
    gap: {{ block.settings.content_gap }}px;
  }

  .ai-content-card__text-box-{{ ai_gen_id }} {
    background-color: {{ block.settings.text_box_background }};
    padding-top: {{ block.settings.text_box_padding_top }}px;
    padding-bottom: {{ block.settings.text_box_padding_bottom }}px;
    padding-left: {{ block.settings.text_box_padding_left }}px;
    padding-right: {{ block.settings.text_box_padding_right }}px;
    border-radius: {{ block.settings.text_box_border_radius }}px;
    max-width: {{ block.settings.text_box_max_width }}%;
  }

  .ai-content-card__heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px 0;
    line-height: 1.2;
  }

  .ai-content-card__text-{{ ai_gen_id }} {
    font-family: {{ block.settings.text_font.family }}, {{ block.settings.text_font.fallback_families }};
    font-weight: {{ block.settings.text_font.weight }};
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
    line-height: 1.5;
  }

  .ai-content-card__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_top }}px {{ block.settings.button_padding_left }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    font-family: {{ block.settings.button_font.family }}, {{ block.settings.button_font.fallback_families }};
    font-weight: {{ block.settings.button_font.weight }};
    font-size: {{ block.settings.button_text_size }}px;
    border-radius: {{ block.settings.button_border_radius }}px;
    text-decoration: none;
    transition: background-color 0.3s ease;
  }

  .ai-content-card__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  @media screen and (max-width: 749px) {
    .ai-content-card-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-content-card__content-{{ ai_gen_id }} {
      padding-top: {{ block.settings.padding_top | times: 0.7 | round }}px;
      padding-bottom: {{ block.settings.padding_bottom | times: 0.7 | round }}px;
      padding-left: {{ block.settings.padding_left | times: 0.7 | round }}px;
      padding-right: {{ block.settings.padding_right | times: 0.7 | round }}px;
    }

    .ai-content-card__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 | round }}px;
    }

    .ai-content-card__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 | round }}px;
    }

    .ai-content-card__text-box-{{ ai_gen_id }} {
      max-width: 100%;
    }
  }
{% endstyle %}

<content-card-{{ ai_gen_id }} class="ai-content-card-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-content-card__background-{{ ai_gen_id }}">
    {% if block.settings.background_image %}
      <img
        src="{{ block.settings.background_image | image_url: width: 2000 }}"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
      >
    {% else %}
      <div class="ai-content-card__background-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
      </div>
    {% endif %}
  </div>

  {% if block.settings.overlay_opacity > 0 %}
    <div class="ai-content-card__overlay-{{ ai_gen_id }}"></div>
  {% endif %}

  <div class="ai-content-card__content-{{ ai_gen_id }}">
    <div class="ai-content-card__text-box-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-content-card__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}

      {% if block.settings.text != blank %}
        <div class="ai-content-card__text-{{ ai_gen_id }}">{{ block.settings.text }}</div>
      {% endif %}
    </div>

    {% if block.settings.button_text != blank %}
      <a
        href="{{ block.settings.button_link }}"
        class="ai-content-card__button-{{ ai_gen_id }}"
      >
        {{ block.settings.button_text }}
      </a>
    {% endif %}
  </div>
</content-card-{{ ai_gen_id }}>

<script>
  (function() {
    class ContentCard{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }
    customElements.define('content-card-{{ ai_gen_id }}', ContentCard{{ ai_gen_id }});
  })();
</script>

