{% doc %}
  @prompt
    create a box that can have an image in it, i need to be able to fully control the height and the width of the box. please provide all functions for editing the size of the box. i need to be able to adjust the radius of the corners. please do all necessary controls for editing for mobile and for desktop  
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-box-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-image-box-container-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
    margin: 0 auto;
  }

  @media screen and (min-width: 750px) {
    .ai-image-box-container-{{ ai_gen_id }} {
      width: {{ block.settings.desktop_width }}px;
      height: {{ block.settings.desktop_height }}px;
      border-radius: {{ block.settings.desktop_border_radius }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-image-box-container-{{ ai_gen_id }} {
      width: {{ block.settings.mobile_width }}%;
      height: {{ block.settings.mobile_height }}px;
      border-radius: {{ block.settings.mobile_border_radius }}px;
    }
  }

  .ai-image-box-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: {{ block.settings.image_fit }};
    object-position: {{ block.settings.image_position }};
  }

  .ai-image-box-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-image-box-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    max-width: 200px;
    max-height: 200px;
    opacity: 0.3;
  }

  .ai-image-box-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 8px 16px;
    background-color: rgba(0, 0, 0, 0.6);
    color: #ffffff;
    font-size: 14px;
    border-radius: 4px;
    text-align: center;
    pointer-events: none;
  }
{% endstyle %}

<div class="ai-image-box-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-image-box-container-{{ ai_gen_id }}">
    {% if block.settings.image %}
      <img
        src="{{ block.settings.image | image_url: width: 2000 }}"
        alt="{{ block.settings.image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.image.width }}"
        height="{{ block.settings.image.height }}"
        class="ai-image-box-image-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-image-box-placeholder-{{ ai_gen_id }}">
        {{ 'image' | placeholder_svg_tag }}
        <div class="ai-image-box-empty-state-{{ ai_gen_id }}">
          Add an image
        </div>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Image box",
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_fit",
      "label": "Image fit",
      "options": [
        {
          "value": "cover",
          "label": "Cover"
        },
        {
          "value": "contain",
          "label": "Contain"
        },
        {
          "value": "fill",
          "label": "Fill"
        }
      ],
      "default": "cover"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "top",
          "label": "Top"
        },
        {
          "value": "bottom",
          "label": "Bottom"
        },
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Desktop dimensions"
    },
    {
      "type": "range",
      "id": "desktop_width",
      "label": "Width",
      "min": 100,
      "max": 2000,
      "step": 50,
      "unit": "px",
      "default": 800
    },
    {
      "type": "range",
      "id": "desktop_height",
      "label": "Height",
      "min": 100,
      "max": 1000,
      "step": 50,
      "unit": "px",
      "default": 500
    },
    {
      "type": "range",
      "id": "desktop_border_radius",
      "label": "Corner radius",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Mobile dimensions"
    },
    {
      "type": "range",
      "id": "mobile_width",
      "label": "Width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "mobile_height",
      "label": "Height",
      "min": 100,
      "max": 800,
      "step": 50,
      "unit": "px",
      "default": 300
    },
    {
      "type": "range",
      "id": "mobile_border_radius",
      "label": "Corner radius",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Image box"
    }
  ],
  "tag": null
}
{% endschema %}
