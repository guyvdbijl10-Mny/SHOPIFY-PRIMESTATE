{% doc %}
  @prompt
    create a section that has: image backround, text box that has colour backround and opacity slider, learn more tab in the bottom, i need to adjust the padding on the entire section and edit the radius on the entire section, only do adjustments for mobile functions , i dont want the text to be effected by the opacity slider. only the backorund of the text box. and i want the learn more button to be seperated from the text box. i also need to edit the texts fonts and size, please make padding options seperate 
    
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-text-section-{{ ai_gen_id }} {
    display: block;
    position: relative;
    width: 100%;
    padding-top: {{ block.settings.padding_top_mobile }}px;
    padding-bottom: {{ block.settings.padding_bottom_mobile }}px;
    padding-left: {{ block.settings.padding_left_mobile }}px;
    padding-right: {{ block.settings.padding_right_mobile }}px;
    border-radius: {{ block.settings.section_border_radius_mobile }}px;
    overflow: hidden;
  }

  .ai-image-text-section__background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .ai-image-text-section__background-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-image-text-section__background-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-image-text-section__background-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-image-text-section__content-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.content_gap_mobile }}px;
    align-items: {{ block.settings.content_alignment_mobile }};
  }

  .ai-image-text-section__text-box-{{ ai_gen_id }} {
    position: relative;
    padding-top: {{ block.settings.text_box_padding_top_mobile }}px;
    padding-bottom: {{ block.settings.text_box_padding_bottom_mobile }}px;
    padding-left: {{ block.settings.text_box_padding_left_mobile }}px;
    padding-right: {{ block.settings.text_box_padding_right_mobile }}px;
    border-radius: {{ block.settings.text_box_border_radius_mobile }}px;
    max-width: 100%;
    width: 100%;
  }

  .ai-image-text-section__text-box-bg-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.text_box_bg_color }};
    opacity: {{ block.settings.text_box_bg_opacity }};
    border-radius: {{ block.settings.text_box_border_radius_mobile }}px;
    z-index: 1;
  }

  .ai-image-text-section__text-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
  }

  .ai-image-text-section__heading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.heading_margin_bottom_mobile }}px 0;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_font_size_mobile }}px;
    line-height: 1.2;
    font-weight: {{ block.settings.heading_font_weight }};
  }

  .ai-image-text-section__text-{{ ai_gen_id }} {
    margin: 0;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_font_size_mobile }}px;
    line-height: 1.5;
    font-weight: {{ block.settings.text_font_weight }};
  }

  .ai-image-text-section__button-{{ ai_gen_id }} {
    display: inline-block;
    padding-top: {{ block.settings.button_padding_top_mobile }}px;
    padding-bottom: {{ block.settings.button_padding_bottom_mobile }}px;
    padding-left: {{ block.settings.button_padding_left_mobile }}px;
    padding-right: {{ block.settings.button_padding_right_mobile }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius_mobile }}px;
    font-size: {{ block.settings.button_font_size_mobile }}px;
    font-weight: {{ block.settings.button_font_weight }};
    transition: background-color 0.3s ease;
    text-align: center;
  }

  .ai-image-text-section__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
  }
{% endstyle %}

<div class="ai-image-text-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-image-text-section__background-{{ ai_gen_id }}">
    {% if block.settings.background_image %}
      <img
        src="{{ block.settings.background_image | image_url: width: 1500 }}"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
      >
    {% else %}
      <div class="ai-image-text-section__background-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
      </div>
    {% endif %}
  </div>

  <div class="ai-image-text-section__content-{{ ai_gen_id }}">
    <div class="ai-image-text-section__text-box-{{ ai_gen_id }}">
      <div class="ai-image-text-section__text-box-bg-{{ ai_gen_id }}"></div>
      <div class="ai-image-text-section__text-content-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-image-text-section__heading-{{ ai_gen_id }}">
            {{ block.settings.heading }}
          </h2>
        {% endif %}
        {% if block.settings.text != blank %}
          <div class="ai-image-text-section__text-{{ ai_gen_id }}">
            {{ block.settings.text }}
          </div>
        {% endif %}
      </div>
    </div>

    {% if block.settings.button_text != blank %}
      <a
        href="{{ block.settings.button_link }}"
        class="ai-image-text-section__button-{{ ai_gen_id }}"
      >
        {{ block.settings.button_text }}
      </a>
    {% endif %}
  </div>
</div>

