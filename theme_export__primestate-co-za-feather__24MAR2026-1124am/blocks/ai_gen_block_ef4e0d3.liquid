{% doc %}
  @prompt
    white bsckround with text box, left and right padding,top/bottom, edit font, i need to be able to edit the size of the heading of this and the fonts body , this has not worked. please re do everything. i dont want desktop options, just a text box that has a seperate heading section and a body section so that the font can be different between the two, i also need to change the font
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-text-box-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    padding-left: {{ block.settings.padding_left }}px;
    padding-right: {{ block.settings.padding_right }}px;
  }

  .ai-text-box-heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_font_size }}px;
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-style: {{ block.settings.heading_font.style }};
    margin: 0 0 {{ block.settings.spacing_between }}px 0;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-text-box-body-{{ ai_gen_id }} {
    color: {{ block.settings.body_color }};
    font-size: {{ block.settings.body_font_size }}px;
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-style: {{ block.settings.body_font.style }};
    line-height: {{ block.settings.line_height }};
    text-align: {{ block.settings.text_alignment }};
  }
{% endstyle %}

<div class="ai-text-box-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank %}
    <div class="ai-text-box-heading-{{ ai_gen_id }}">
      {{ block.settings.heading }}
    </div>
  {% endif %}
  
  {% if block.settings.body_text != blank %}
    <div class="ai-text-box-body-{{ ai_gen_id }}">
      {{ block.settings.body_text }}
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Text box",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading text",
      "default": "<p>Your heading here</p>"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading font",
      "default": "serif"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading font size",
      "min": 16,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Body"
    },
    {
      "type": "richtext",
      "id": "body_text",
      "label": "Body text",
      "default": "<p>Your body text goes here. This can be longer and more detailed.</p>"
    },
    {
      "type": "font_picker",
      "id": "body_font",
      "label": "Body font",
      "default": "sans-serif"
    },
    {
      "type": "range",
      "id": "body_font_size",
      "label": "Body font size",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Body color",
      "default": "#110811"
    },
    {
      "type": "range",
      "id": "spacing_between",
      "label": "Space between heading and body",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 15
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "line_height",
      "label": "Line height",
      "options": [
        {
          "value": "1.2",
          "label": "Tight"
        },
        {
          "value": "1.5",
          "label": "Normal"
        },
        {
          "value": "1.8",
          "label": "Loose"
        }
      ],
      "default": "1.5"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_left",
      "label": "Left",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_right",
      "label": "Right",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Text box"
    }
  ]
}
{% endschema %}
