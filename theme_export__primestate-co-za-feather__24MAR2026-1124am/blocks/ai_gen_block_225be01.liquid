{% doc %}
  @prompt
    Create a custom section with adjustable padding controls for all four sides (top, bottom, left, right) that can be adjusted independently. Include an image upload field and text content area. The section should be mobile-responsive with clean, minimal design suitable for health supplement products., put the text over the image and use the image as the backround for the text , i want to be able to make the text of the heading bold 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-content-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    padding-left: {{ block.settings.padding_left }}px;
    padding-right: {{ block.settings.padding_right }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-content-section__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    position: relative;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
    min-height: {{ block.settings.min_height }}px;
  }

  .ai-content-section__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }

  .ai-content-section__image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
  }

  .ai-content-section__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-content-section__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
    z-index: 3;
  }

  .ai-content-section__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
    z-index: 2;
  }

  .ai-content-section__text-wrapper-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    padding: {{ block.settings.text_padding_top }}px {{ block.settings.text_padding_right }}px {{ block.settings.text_padding_bottom }}px {{ block.settings.text_padding_left }}px;
    display: flex;
    flex-direction: column;
    justify-content: {{ block.settings.vertical_alignment }};
    align-items: {{ block.settings.horizontal_alignment }};
    min-height: {{ block.settings.min_height }}px;
    text-align: {% if block.settings.horizontal_alignment == 'flex-start' %}left{% elsif block.settings.horizontal_alignment == 'flex-end' %}right{% else %}center{% endif %};
  }

  .ai-content-section__content-{{ ai_gen_id }} {
    max-width: {{ block.settings.text_max_width }}px;
  }

  .ai-content-section__heading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1.2;
    font-weight: {% if block.settings.heading_bold %}700{% else %}400{% endif %};
  }

  .ai-content-section__text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
  }

  .ai-content-section__text-{{ ai_gen_id }} p {
    margin: 0 0 16px;
  }

  .ai-content-section__text-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-content-section-{{ ai_gen_id }} {
      padding-top: {{ block.settings.padding_top_mobile }}px;
      padding-bottom: {{ block.settings.padding_bottom_mobile }}px;
      padding-left: {{ block.settings.padding_left_mobile }}px;
      padding-right: {{ block.settings.padding_right_mobile }}px;
    }

    .ai-content-section__container-{{ ai_gen_id }} {
      min-height: {{ block.settings.min_height_mobile }}px;
    }

    .ai-content-section__text-wrapper-{{ ai_gen_id }} {
      padding: {{ block.settings.text_padding_top_mobile }}px {{ block.settings.text_padding_right_mobile }}px {{ block.settings.text_padding_bottom_mobile }}px {{ block.settings.text_padding_left_mobile }}px;
      min-height: {{ block.settings.min_height_mobile }}px;
    }

    .ai-content-section__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
    }

    .ai-content-section__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-content-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-content-section__container-{{ ai_gen_id }}">
    {% if block.settings.image %}
      <img
        src="{{ block.settings.image | image_url: width: 1600 }}"
        alt="{{ block.settings.image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.image.width }}"
        height="{{ block.settings.image.height }}"
        class="ai-content-section__image-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-content-section__image-placeholder-{{ ai_gen_id }}">
        {{ 'image' | placeholder_svg_tag }}
        <div class="ai-content-section__empty-state-{{ ai_gen_id }}">
          Add a background image
        </div>
      </div>
    {% endif %}

    <div class="ai-content-section__overlay-{{ ai_gen_id }}"></div>

    <div class="ai-content-section__text-wrapper-{{ ai_gen_id }}">
      <div class="ai-content-section__content-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-content-section__heading-{{ ai_gen_id }}">
            {{ block.settings.heading }}
          </h2>
        {% endif %}

        {% if block.settings.text != blank %}
          <div class="ai-content-section__text-{{ ai_gen_id }}">
            {{ block.settings.text }}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

