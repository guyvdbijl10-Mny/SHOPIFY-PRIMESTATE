{% doc %}
  @prompt
    create a section that has: image backround, text box that has colour backround and opacity slider, learn more tab in the bottom, i need to adjust the padding on the entire section and edit the radius on the entire section, only do adjustments for mobile functions , i dont want the text to be effected by the opacity slider. only the backorund of the text box. and i want the learn more button to be seperated from the text box. i also need to edit the texts fonts and size, please make padding options seperate, add and opacity slider to the backround colour of the learn more tab. i also dont want the text of the backround to become lighter when i use the opacity slider, i dont want the text to become lighter when i use the opacity slider for the main text box 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% liquid
  assign text_box_bg_r = block.settings.text_box_color | color_extract: 'red'
  assign text_box_bg_g = block.settings.text_box_color | color_extract: 'green'
  assign text_box_bg_b = block.settings.text_box_color | color_extract: 'blue'
  assign text_box_opacity = block.settings.text_box_opacity | divided_by: 100.0

  assign button_bg_r = block.settings.button_background | color_extract: 'red'
  assign button_bg_g = block.settings.button_background | color_extract: 'green'
  assign button_bg_b = block.settings.button_background | color_extract: 'blue'
  assign button_opacity = block.settings.button_opacity | divided_by: 100.0

  assign button_hover_r = block.settings.button_hover_background | color_extract: 'red'
  assign button_hover_g = block.settings.button_hover_background | color_extract: 'green'
  assign button_hover_b = block.settings.button_hover_background | color_extract: 'blue'
%}

{% style %}
  .ai-image-text-section-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    display: block;
    padding: {{ block.settings.padding_top_mobile }}px {{ block.settings.padding_horizontal_mobile }}px {{ block.settings.padding_bottom_mobile }}px;
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
  }

  .ai-image-text-background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .ai-image-text-background-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-image-text-background-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-image-text-background-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-image-text-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.button_spacing }}px;
  }

  .ai-image-text-box-{{ ai_gen_id }} {
    background-color: rgba({{ text_box_bg_r }}, {{ text_box_bg_g }}, {{ text_box_bg_b }}, {{ text_box_opacity }});
    padding: {{ block.settings.text_box_padding_top }}px {{ block.settings.text_box_padding_horizontal }}px {{ block.settings.text_box_padding_bottom }}px;
    border-radius: {{ block.settings.text_box_border_radius }}px;
  }

  .ai-image-text-heading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.text_spacing }}px;
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1.2;
    color: {{ block.settings.heading_color }};
  }

  .ai-image-text-description-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.5;
    color: {{ block.settings.text_color }};
  }

  .ai-image-text-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: rgba({{ button_bg_r }}, {{ button_bg_g }}, {{ button_bg_b }}, {{ button_opacity }});
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    text-align: center;
    transition: background-color 0.3s ease;
    align-self: flex-start;
  }

  .ai-image-text-button-{{ ai_gen_id }}:hover {
    background-color: rgba({{ button_hover_r }}, {{ button_hover_g }}, {{ button_hover_b }}, {{ button_opacity }});
  }
{% endstyle %}

<div class="ai-image-text-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-image-text-background-{{ ai_gen_id }}">
    {% if block.settings.background_image %}
      <img
        src="{{ block.settings.background_image | image_url: width: 2000 }}"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
      >
    {% else %}
      <div class="ai-image-text-background-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
      </div>
    {% endif %}
  </div>

  <div class="ai-image-text-content-{{ ai_gen_id }}">
    <div class="ai-image-text-box-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-image-text-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}

      {% if block.settings.description != blank %}
        <div class="ai-image-text-description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
      {% endif %}
    </div>

    {% if block.settings.button_text != blank %}
      <a
        href="{{ block.settings.button_link }}"
        class="ai-image-text-button-{{ ai_gen_id }}"
      >
        {{ block.settings.button_text }}
      </a>
    {% endif %}
  </div>
</div>

