{% doc %}
  @prompt
    create a section that has an image for the backround, a text box that can have the colour adjusted and the text box must have an opacity slider. the text must not be affected by the opacity slider only the text box colour. give full width and height control of the backround image and be able to adjust the radius. functions for desktop and mobile 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-text-overlay-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    display: block;
  }

  .ai-image-text-overlay__background-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
  }

  .ai-image-text-overlay__image-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.image_height_desktop }}px;
    object-fit: cover;
    display: block;
  }

  .ai-image-text-overlay__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.image_height_desktop }}px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-image-text-overlay__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-image-text-overlay__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-image-text-overlay__content-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: {{ block.settings.text_box_width_desktop }}%;
    max-width: 100%;
    padding: {{ block.settings.text_box_padding }}px;
    border-radius: {{ block.settings.text_box_border_radius }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-image-text-overlay__content-bg-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.text_box_color }};
    opacity: {{ block.settings.text_box_opacity | divided_by: 100.0 }};
    border-radius: {{ block.settings.text_box_border_radius }}px;
    z-index: 1;
  }

  .ai-image-text-overlay__text-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-image-text-overlay__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.text_spacing }}px 0;
    color: {{ block.settings.text_color }};
  }

  .ai-image-text-overlay__subtext-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtext_size }}px;
    margin: 0;
    color: {{ block.settings.text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-image-text-overlay__image-{{ ai_gen_id }} {
      height: {{ block.settings.image_height_mobile }}px;
    }

    .ai-image-text-overlay__placeholder-{{ ai_gen_id }} {
      height: {{ block.settings.image_height_mobile }}px;
    }

    .ai-image-text-overlay__background-{{ ai_gen_id }} {
      border-radius: {{ block.settings.image_border_radius_mobile }}px;
    }

    .ai-image-text-overlay__content-{{ ai_gen_id }} {
      width: {{ block.settings.text_box_width_mobile }}%;
      border-radius: {{ block.settings.text_box_border_radius_mobile }}px;
    }

    .ai-image-text-overlay__content-bg-{{ ai_gen_id }} {
      border-radius: {{ block.settings.text_box_border_radius_mobile }}px;
    }

    .ai-image-text-overlay__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
    }

    .ai-image-text-overlay__subtext-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtext_size_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-image-text-overlay-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-image-text-overlay__background-{{ ai_gen_id }}">
    {% if block.settings.background_image %}
      <img
        src="{{ block.settings.background_image | image_url: width: 2000 }}"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
        class="ai-image-text-overlay__image-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-image-text-overlay__placeholder-{{ ai_gen_id }}">
        {{ 'lifestyle-1' | placeholder_svg_tag }}
        <div class="ai-image-text-overlay__empty-state-{{ ai_gen_id }}">
          Add a background image
        </div>
      </div>
    {% endif %}

    <div class="ai-image-text-overlay__content-{{ ai_gen_id }}">
      <div class="ai-image-text-overlay__content-bg-{{ ai_gen_id }}"></div>
      <div class="ai-image-text-overlay__text-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-image-text-overlay__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subtext != blank %}
          <div class="ai-image-text-overlay__subtext-{{ ai_gen_id }}">{{ block.settings.subtext }}</div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Image with text overlay",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Background image"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Image"
    },
    {
      "type": "range",
      "id": "image_height_desktop",
      "label": "Desktop height",
      "min": 200,
      "max": 800,
      "step": 50,
      "unit": "px",
      "default": 500
    },
    {
      "type": "range",
      "id": "image_height_mobile",
      "label": "Mobile height",
      "min": 200,
      "max": 600,
      "step": 50,
      "unit": "px",
      "default": 400
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Desktop border radius",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "image_border_radius_mobile",
      "label": "Mobile border radius",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Text content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Your heading here"
    },
    {
      "type": "inline_richtext",
      "id": "subtext",
      "label": "Subtext",
      "default": "Add your message or description"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Desktop heading size",
      "min": 16,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Mobile heading size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "subtext_size",
      "label": "Desktop subtext size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "subtext_size_mobile",
      "label": "Mobile subtext size",
      "min": 12,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "text_spacing",
      "label": "Spacing between heading and subtext",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Text box style"
    },
    {
      "type": "color",
      "id": "text_box_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "text_box_opacity",
      "label": "Background opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 50
    },
    {
      "type": "range",
      "id": "text_box_width_desktop",
      "label": "Desktop width",
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 60
    },
    {
      "type": "range",
      "id": "text_box_width_mobile",
      "label": "Mobile width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 90
    },
    {
      "type": "range",
      "id": "text_box_padding",
      "label": "Padding",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "text_box_border_radius",
      "label": "Desktop border radius",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "text_box_border_radius_mobile",
      "label": "Mobile border radius",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Image with text overlay"
    }
  ]
}
{% endschema %}
